#############################################
# InstantX .gitignore
# Stack: Python (Flask + Poetry/pytest), Docker Compose,
#        Apache NiFi + Kafka + HiveMQ (vendored .jar/.nar/.gz binaries)
#
# NOTE: .jar, .nar and flow.json.gz are intentionally committed as
# vendored artifacts — do NOT add blanket *.jar / *.nar / *.gz patterns.
#############################################

# === OS files ===
.DS_Store
Thumbs.db

# === Editors / IDEs ===
*.swp
*.swo
.vscode/
.idea/
*.iml
# Eclipse
.project
.classpath
.settings/

# === AI assistants & coding agents ===
# CLAUDE.md and any shared .claude/ config are intentionally committed —
# only local-only / per-developer AI artifacts are ignored here.
.claude/settings.local.json
CLAUDE.local.md
# Use AGENTS.md instead
CLAUDE.md
# Aider (chat history, input history, tag cache)
.aider*
# Cursor (local indexing hints)
.cursorindexingignore
# Windsurf / Codeium
.windsurf/
.codeium/
# Continue.dev
.continue/
# Gemini CLI / OpenAI Codex local state
.gemini/
.codex/
# Misc AI scratch dirs & local model weights
.ai/
*.gguf
*.ggml

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so

# Packaging / build
build/
dist/
.eggs/
*.egg
*.egg-info/

# Test & coverage (pytest, coverage.xml from `poetry run pytest --cov`)
.cache
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# === Node / website (website/ — React + Vite landing page) ===
node_modules/
website/dist/
*.tsbuildinfo
npm-debug.log*

# === Environments & secrets ===
.env
.env.*
!.env.example
.venv
venv/
env/
ENV/

# Flask
instance/
.webassets-cache

# === Docker ===
docker-compose.override.yml
docker-compose.override.yaml

# === JVM build output (NiFi/Kafka source builds only; vendored jars/nars stay) ===
target/
*.class
*.war
*.ear

# === Apache NiFi runtime (generated when running NiFi locally) ===
/logs/
/database_repository/
/content_repository/
/flowfile_repository/
/provenance_repository/
/state/
/temp/
/work/

# === NiFi sensitive config (never commit) ===
/conf/passwords.properties
/conf/authorizations.xml
/conf/users.xml
/conf/login-identity-providers.xml
/conf/bootstrap.conf
/conf/bootstrap-notification-services.xml

# === Logs, local databases & runtime state ===
*.log
**/*.log
**/*.db
**/*.db-shm
**/*.db-wal
**/*.journal
# Note: website/package-lock.json is intentionally committed (npm ci needs
# it); it does not match this pattern, which targets runtime lock files.
**/*.lock
checkpoint
snapshot
